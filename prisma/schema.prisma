generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
}

enum SocialAccountStatus {
  ACTIVE
  BANNED
  PENDING
  DISCONNECTED
}

enum ContentStatus {
  DRAFT
  APPROVED
  SCHEDULED
  POSTED
}

enum PostStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
}

// New enums for the clipping engine

enum SourceType {
  YOUTUBE_URL
  FILE_UPLOAD
}

enum IngestionStatus {
  PENDING
  TRANSCRIBING
  TRANSCRIBED
  ANALYZING
  ANALYZED
  GENERATING
  COMPLETE
  ERROR
}

enum ClipType {
  HOT_TAKE
  EMOTIONAL
  QUOTABLE
  STORY
  REVEAL
  RELATABLE
}

enum ClipStatus {
  GENERATED
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

enum PublishStatus {
  QUEUED
  UPLOADING
  PROCESSING
  PUBLISHED
  FAILED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        WorkspaceMember[]
  socialAccounts SocialAccount[]
  content        ContentPiece[]
  funnels        Funnel[]
  leads          Lead[]
  publishLogs    PublishLog[]
  clipDetections ClipDetection[]
  sourceVideos   SourceVideo[]
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces WorkspaceMember[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

// ─── Social Accounts ─────────────────────────────────────────────────────────

model SocialAccount {
  id                String              @id @default(cuid())
  workspaceId       String
  platform          Platform
  username          String
  displayName       String?
  avatarUrl         String?
  accessToken       String?             // AES-256 encrypted
  refreshToken      String?             // AES-256 encrypted
  tokenExpiresAt    DateTime?
  platformAccountId String?             // Platform's user/account ID
  scopes            String[]            @default([])
  status            SocialAccountStatus @default(PENDING)
  followerCount     Int?
  tags              String[]            @default([])
  proxyConfig       String?             // JSON string for proxy settings
  isActive          Boolean             @default(true)
  lastPostedAt      DateTime?
  lastSyncedAt      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishLogs PublishLog[]
  analytics   Analytics[]

  @@index([workspaceId])
  @@index([workspaceId, platform])
}

// ─── Content (existing Content Studio) ───────────────────────────────────────

model ContentPiece {
  id            String        @id @default(cuid())
  workspaceId   String
  title         String?
  rawInput      String        // Text script or S3 URL for video
  platform      Platform
  hook          String?
  caption       String?
  hashtags      String[]      @default([])
  cta           String?
  scriptShort   String?       // Trimmed script variant
  youtubeTitle  String?
  thumbnailText String?
  status        ContentStatus @default(DRAFT)
  scheduledAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  publishLogs PublishLog[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

// ─── Source Videos (long-form ingestion) ─────────────────────────────────────

model SourceVideo {
  id             String          @id @default(cuid())
  workspaceId    String
  title          String
  sourceType     SourceType
  sourceUrl      String?         // YouTube URL
  sourceFilePath String?         // S3/storage path
  duration       Int?            // total seconds
  transcript     String?         @db.Text
  clipAnalysis   Json?           // Claude's raw JSON response
  goal           String?         // user's selected goal for this video
  goalSettings   Json?           // { tone, niche, targetAudience, linkUrl, productName, customGoalText, maxClips, captionStyle }
  status         IngestionStatus @default(PENDING)
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clips     Clip[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

// ─── Clips (short-form clips from source videos) ────────────────────────────

model Clip {
  id                   String     @id @default(cuid())
  sourceVideoId        String
  title                String
  startTime            String     // "MM:SS"
  endTime              String     // "MM:SS"
  duration             Int        // seconds
  viralityScore        Int        // 1-10
  clipType             ClipType
  hook                 String?
  suggestedCaption     String?
  suggestedHashtags    String[]   @default([])
  viralityReason       String?
  transcriptExcerpt    String?
  videoPath            String?    // path to generated clip file
  thumbnailPath        String?
  srtPath              String?    // subtitle file
  status               ClipStatus @default(GENERATED)
  // AI Copywriting fields
  hookText             String?    // On-screen hook text (max 15 words)
  captions             Json?      // { tiktok: [{style,text,cta}x3], instagram: [{style,text,cta}x3] }
  hashtagSets          Json?      // { tiktok: string[], instagram: string[] }
  selectedCaptionStyle String?    @default("curiosity")
  goal                 String?    // Goal used to generate copy
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  sourceVideo SourceVideo  @relation(fields: [sourceVideoId], references: [id], onDelete: Cascade)
  publishLogs PublishLog[]

  @@index([sourceVideoId])
  @@index([sourceVideoId, viralityScore(sort: Desc)])
}

// ─── Publishing ──────────────────────────────────────────────────────────────

model PublishLog {
  id              String        @id @default(cuid())
  workspaceId     String
  contentPieceId  String?
  clipId          String?
  socialAccountId String
  platform        Platform?
  status          PostStatus    @default(PENDING)
  publishStatus   PublishStatus @default(QUEUED)
  caption         String?
  hashtags        String[]      @default([])
  scheduledAt     DateTime?
  executedAt      DateTime?
  publishedAt     DateTime?
  errorMessage    String?
  platformPostId  String?       // ID returned by the platform after posting
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentPiece  ContentPiece?  @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)
  clip          Clip?          @relation(fields: [clipId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  analytics     Analytics[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([socialAccountId])
  @@index([clipId])
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model Analytics {
  id              String   @id @default(cuid())
  publishLogId    String
  socialAccountId String
  views           Int      @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  saves           Int      @default(0)
  reach           Int      @default(0)
  impressions     Int      @default(0)
  engagementRate  Float    @default(0)
  fetchedAt       DateTime @default(now())
  rawData         Json?
  createdAt       DateTime @default(now())

  publishLog    PublishLog    @relation(fields: [publishLogId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([publishLogId])
  @@index([socialAccountId])
  @@index([fetchedAt])
}

// ─── Clip Detection (standalone transcript analysis) ─────────────────────────

model ClipDetection {
  id             String   @id @default(cuid())
  workspaceId    String
  videoTitle     String?
  channelName    String?
  niche          String?
  targetAudience String?
  videoSummary   String?
  totalDuration  Int?     // seconds
  clipsJson      Json     @default("[]") // full detected clips array
  clipsCount     Int      @default(0)
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─── Funnels & Leads ─────────────────────────────────────────────────────────

model Funnel {
  id          String    @id @default(cuid())
  workspaceId String
  slug        String    @unique
  title       String
  blocks      Json      @default("[]")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@index([workspaceId])
}

model Lead {
  id             String     @id @default(cuid())
  workspaceId    String
  funnelId       String
  name           String?
  email          String?
  phone          String?
  status         LeadStatus @default(NEW)
  tags           String[]   @default([])
  notes          String?
  notesUpdatedAt DateTime?
  customFields   Json?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  referrer       String?
  ipAddress      String?
  userAgent      String?
  pageUrl        String?
  submittedAt    DateTime   @default(now())

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  funnel    Funnel     @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  events    LeadEvent[]

  @@index([workspaceId])
  @@index([funnelId])
  @@index([workspaceId, status])
  @@index([workspaceId, submittedAt(sort: Desc)])
}

model LeadEvent {
  id          String   @id @default(cuid())
  leadId      String
  type        String   // "created" | "status_changed" | "note_added" | "tag_added"
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}
